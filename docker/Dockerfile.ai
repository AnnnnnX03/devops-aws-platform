# docker/Dockerfile.ai
FROM python:3.11-slim

WORKDIR /app

COPY app/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt httpx

COPY app/backend/ai_service.py .

RUN useradd --create-home appuser
USER appuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD python -c "import httpx; httpx.get('http://localhost:8001/health')"

CMD ["uvicorn", "ai_service:app", "--host", "0.0.0.0", "--port", "8001"]
